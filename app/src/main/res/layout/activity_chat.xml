<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/raizChat"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_pantalla_degradado"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/fondo_cabecera"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titulo_chat"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoTituloChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/textoSinMensajes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/sin_mensajes"
        android:textColor="@color/texto_secundario"
        android:textSize="15sp" />

    <ListView
        android:id="@+id/listaMensajes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/fondo_tarjeta"
        android:dividerHeight="8dp"
        android:padding="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/fondo_tarjeta"
        android:orientation="horizontal"
        android:padding="10dp">

        <EditText
            android:id="@+id/campoMensaje"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/fondo_campo"
            android:hint="@string/mensaje"
            android:inputType="textCapSentences|textMultiLine"
            android:importantForAutofill="no"
            android:padding="12dp"
            android:textColor="@color/texto_principal"
            android:textColorHint="@color/texto_secundario" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/botonEnviarMensaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/fondo_boton_principal"
            app:backgroundTint="@null"
            android:text="@string/enviar_mensaje"
            android:textColor="@color/white" />
    </LinearLayout>
</LinearLayout>
