<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/raizPrincipal"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_pantalla_degradado"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/fondo_cabecera"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/textoTituloInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titulo_inicio"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoSubtituloInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/subtitulo_inicio"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/fondo_chip_categoria"
            android:paddingStart="12dp"
            android:paddingTop="4dp"
            android:paddingEnd="12dp"
            android:paddingBottom="4dp"
            android:text="@string/organiza_tu_dia"
            android:textColor="@color/azul_oscuro"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/fondo_resumen"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/resumen_tareas"
            android:textColor="@color/azul_oscuro"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/fondo_resumen_total"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:id="@+id/textoTotalTareas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contador_cero"
                    android:textColor="@color/azul_oscuro"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_tareas"
                    android:textColor="@color/texto_secundario"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/fondo_resumen_pendientes"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:id="@+id/textoPendientesTareas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contador_cero"
                    android:textColor="@color/amarillo_suave"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pendientes_tareas"
                    android:textColor="@color/texto_secundario"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:background="@drawable/fondo_resumen_completadas"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp">

                <TextView
                    android:id="@+id/textoCompletadasTareas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/contador_cero"
                    android:textColor="@color/verde_oscuro"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/completadas_tareas"
                    android:textColor="@color/texto_secundario"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/fondo_tarjeta"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/acciones_rapidas"
            android:textColor="@color/azul_oscuro"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/botonAnadirTarea"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/fondo_boton_principal"
                app:backgroundTint="@null"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="@string/nueva_tarea"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/botonCalendario"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/fondo_boton_secundario"
                app:backgroundTint="@null"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="@string/ver_calendario"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/botonPeticiones"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/fondo_boton_peticiones"
                app:backgroundTint="@null"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="@string/ver_peticiones"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/botonCerrarSesion"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/fondo_boton_salida"
                app:backgroundTint="@null"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="@string/cerrar_sesion"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/fondo_tarjeta"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/filtrar_tareas"
                android:textColor="@color/azul_oscuro"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/ayuda_filtrar_tareas"
                android:textColor="@color/texto_secundario"
                android:textSize="10sp" />
        </LinearLayout>

        <Spinner
            android:id="@+id/selectorOrden"
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/fondo_campo"
            android:padding="6dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textoVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/sin_tareas"
        android:textColor="@color/texto_secundario"
        android:textSize="13sp" />

    <ListView
        android:id="@+id/listaTareas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:dividerHeight="8dp" />

</LinearLayout>
