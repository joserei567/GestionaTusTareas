<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/raizCalendario"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_pantalla_degradado"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/fondo_cabecera"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titulo_calendario"
            android:textColor="@color/white"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/subtitulo_calendario"
            android:textColor="@color/white"
            android:textSize="15sp" />
    </LinearLayout>

    <CalendarView
        android:id="@+id/calendarioTareas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/fondo_tarjeta"
        android:padding="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:background="@drawable/fondo_tarjeta"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/textoFechaSeleccionada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tareas_del_dia"
            android:textColor="@color/azul_oscuro"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textoSinTareasDia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/sin_tareas_dia"
            android:textColor="@color/texto_secundario"
            android:textSize="15sp" />

        <ListView
            android:id="@+id/listaTareasCalendario"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:dividerHeight="10dp" />
    </LinearLayout>
</LinearLayout>
